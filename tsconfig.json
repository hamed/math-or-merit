{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "types": ["vitest/globals"],
    "paths": {
      "$lib/*": ["./src/lib/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
